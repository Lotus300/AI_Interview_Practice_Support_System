{
  "name": "ai-interview-practice-support-system",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "type": "module",
  "scripts": {
    "dev:backend": "node apps/backend/src/server.mjs",
    "dev:frontend": "node apps/frontend/server.mjs",
    "dev": "node apps/backend/src/server.mjs",
    "test": "node --test",
    "test:automation": "node scripts/test-automation.mjs",
    "test:smoke": "node scripts/test-automation.mjs --skip-tests --target",
    "check": "node --check apps/backend/src/server.mjs && node --check apps/frontend/src/app.mjs",
    "typecheck": "npm run check"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.6.0",
    "google-auth-library": "^10.9.0"
  }
}
